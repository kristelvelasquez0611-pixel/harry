{
  "projects": {
    "walmart receipt": {
      "template": "<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<title>Walmart Return Receipt</title>\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n\n<style>\n:root{ --thermal-ink:#111; }\n\nbody{\n  background:#f0f0f0;\n  padding:35px;\n  font-family:\"Abadi MT Condensed Light\", \"Arial Narrow\", sans-serif;\n}\n\n.receipt{\n  width:340px;\n  margin:auto;\n  background:#f7f6f2;\n  padding:18px 20px 20px;\n  box-shadow:0 2px 10px rgba(0,0,0,.15);\n  font-size:15px;\n  line-height:1.25;\n  color:var(--thermal-ink);\n  text-shadow:none\n}\n\n.center{ text-align:center; }\n.spacer{ height:10px; }\n\n.rule{\n  border-top:1px dashed var(--thermal-ink);\n  Opacity:1\n  margin:8px 0;\n}\n\n.logo{\n  display:block;\n  margin:6px auto 2px;\n  max-width:150px;\n  filter: grayscale(100%) contrast(120%) brightness(85%);\n  Opacity:1\n}\n\n.returnTitle{\n  font-weight:700;\n  color:var(--thermal-ink); /* same as everything else */\n  margin-top:6px;\n}\n\n.tc{\n  font-weight:700;\n  text-align:center;\n  margin:10px 0 0px;\n  letter-spacing:0.25px;\n}\n.barcodeViz{\n  width: 100%;   /* full width */\n  height: 38px;\n\n  margin-left: -5px;         /* move left */\n  margin-right: 5px;\n  margin-bottom: 8px;\n\n  position: relative;         /* KEEP */\n  overflow: hidden;           /* KEEP */\n  opacity: 0.88;              /* optional */\n}\n\n.barcodeViz div{\n  background:var(--thermal-ink);\n  Opacity:1\n}\n\n.small{ font-size:15px; }\n.section-gap{ height:10px; }\n\n.indent-line{ padding-left:1.5ch; }\n:root{ --thermal-ink:#111; }\n\n.receipt{\n  color:var(--thermal-ink);\n  text-shadow:none;\n}\n\n/* FORCE everything inside receipt to match */\n.receipt, \n.receipt *{\n  color:var(--thermal-ink) !important;\n  opacity:1 !important;\n  text-shadow:none !important;\n}\n.totals-only{\n  white-space:pre;\n  margin-left:40px; /* adjust this */\n}\n.totals-block{\n  white-space: pre;\n  font-family: \"Abadi MT Condensed Light\", \"Arial Narrow\", sans-serif;\n\n  /* control mo dito galaw */\n  margin-left: 100px; /* adjust mo lang */\n}\n.totals{\n  width: 260px;\n  margin-left: 40px; /* 👈 overall position control */\n  font-family: \"Abadi MT Condensed Light\", \"Arial Narrow\", sans-serif;\n}\n\n.row{\n  display: flex;\n}\n\n/* labels (hindi full left, naka-offset) */\n.label{\n  margin-left: 60px; /* 👈 ito magbibigay ng \"gitna look\" */\n}\n.tax-line{\n  margin-left: -10px; /* 👈 mas malakas na shift pakaliwa */\n  letter-spacing: 1px;\n}\n/* numbers fixed */\n.amt{\n  margin-left: auto;   /* 👈 keeps all numbers aligned */\n  min-width: 70px;     /* 👈 pantay column */\n  text-align: right;\n}\n\n/* TAX special spacing */\n.tax-line{\n  display: inline-flex;\n  gap: 12px;\n}\n\n/* move TAX 1 slightly right */\n.t1{\n  Margin-left: 20px;\n}\n.item-row{\n  display: flex;\n}\n\n/* container ng amount + X */\n.amt-group{\n  margin-left: auto; /* keep alignment sa right column */\n  display: inline-flex;\n  align-items: center;\n\n  transform: translateX(-25px); /* 👈 CONTROL KNOB */\n}\n\n/* main number */\n.amt{\n  min-width: 70px;\n  text-align: right;\n}\n\n/* X spacing */\n.x{\n  margin-left: 6px;\n}\n.top-text{\n  font-size: 15px; /* same as receipt */\n  letter-spacing: 0.9px;\n}\n.card-row{\n  width: 100%;\n}\n.card-line{\n  display: block;\n  width: 100%;\n\n  letter-spacing: 1.07px;      /* 👈 adjust mo */\n  word-spacing: 12px;        /* 👈 ito ang key */\n\n  white-space: nowrap;      /* para hindi mag-break */\n  transform: translateX(-40px); /* 👈 move LEFT */\n}\n.card-info{\n  display: block;\n\n  transform: translateX(-40px); /* 👈 SAME as VISA line */\n\n  letter-spacing: 0.5px;\n  word-spacing: 4px;\n\n  line-height: 1.25;\n}\n.store-line{\n  text-align: center; /* default */\n\n  transform: translateX(0px); /* 👈 CONTROL KNOB */\n  letter-spacing: 0.5px;\n   word-spacing: 4px;\n}\n.roboto-i{\n  font-family: 'Roboto';\n}\n}\n</style>\n</head>\n\n<body>\n<div class=\"receipt\">\n\n<div class=\"top-text\">\n  Give us feedback @ survey.waltermart.com<br>\n  Thank you! ID #: {{FEEDBACK_ID}}\n</div>\n\n  <img src=\"https://i.imgur.com/iJbritE.png\" class=\"logo\" alt=\"Walmart\">\n\n  <div class=\"center\">{{STORE_NAME}}</div>\n\n  <div class=\"center\">\n     {{PHONE}}&nbsp;&nbsp;Mgr. {{MANAGER}}<br>\n     {{ADDRESS_LINE}}<br>\n     {{CITY_STATE_ZIP}}\n </div>\n\n  <div class=\"store-line\">\n  ST# {{STORE_NUMBER}} OP# {{OP}} TE# {{TERMINAL}} TR# {{TRANS}}\n</div>\n\n  <div class=\"center returnTitle\">*** RETURN RECEIPT ***</div>\n\n  <div class=\"tc\" id=\"tcText\">TC# {{TC_NUMBER}}</div>\n\n  <div class=\"barcodeViz\" id=\"barcodeViz\"></div>\n\n  <!-- REPLACED MONEY SECTION -->\n  <div class=\"item\">\n  <div>PRODUCT SERIAL # {{SERIAL}}</div>\n\n  <div class=\"item-row\">\n    <span>{{ITEM_DESC}}</span>\n\n    <span class=\"amt-group\">\n      <span class=\"amt\">{{ITEM_PRICE}}</span>\n      <span class=\"x\">X</span>\n    </span>\n  </div>\n\n<div class=\"totals\">\n  <div class=\"row\">\n    <span class=\"label\">SUBTOTAL</span>\n    <span class=\"amt\">{{SUBTOTAL}}</span>\n  </div>\n\n  <div class=\"row\">\n    <span class=\"label tax-line\">\n      <span class=\"t1\">TAX 1</span>\n      <span class=\"pct\">6.625 %</span>\n    </span>\n    <span class=\"amt\">{{TAX}}</span>\n  </div>\n\n  <div class=\"row\">\n    <span class=\"label\">TOTAL</span>\n    <span class=\"amt\">{{TOTAL}}</span>\n  </div>\n\n  <div class=\"row\">\n    <span class=\"label\">VISA REFUND</span>\n    <span class=\"amt\">{{REFUND}}</span>\n  </div>\n<div class=\"card-line\">\n  {{CARD_TYPE}} **** **** **** {{CARD_LAST4}} <span class=\"roboto-i\">I</span> {{ENTRY_MODE}}\n</div>\n<div class=\"card-info\">\n  APPROVAL # {{APPROVAL}}<br>\n  REF # {{REF}}<br>\n  TRANS ID - {{TRANS_ID}}<br>\n  VALIDATION - {{VALIDATION}}<br>\n  PAYMENT SERVICE - {{PAYMENT_SERVICE}}<br>\n  AID {{AID}}<br>\n  AAC {{AAC}}<br>\n  TERMINAL # {{TERMINAL_ID}}<br>\n  *NO SIGNATURE REQUIRED<br>\n</div>\n  <div style=\"text-align:center;\">\n    {{DATE}}&nbsp;&nbsp;&nbsp;{{TIME}}\n  </div>\n\n</div>\n\n<script>\nconst tcEl = document.getElementById(\"tcText\");\nconst barcode = document.getElementById(\"barcodeViz\");\n\nfunction hashString(s){\n  let h=2166136261;\n  for(let i=0;i<s.length;i++){\n    h ^= s.charCodeAt(i);\n    h = Math.imul(h,16777619);\n  }\n  return h>>>0;\n}\n\nfunction drawBarcode(){\n  barcode.innerHTML=\"\";\n  const digits = tcEl.textContent.replace(/\\D/g,\"\");\n  if(!digits) return;\n\n  const w = barcode.clientWidth;\n  const h = barcode.clientHeight;\n\n  let x = 6;\n  let r = hashString(digits);\n\n  while(x < w - 6){\n    r ^= r<<13; r ^= r>>>17; r ^= r<<5;\n\n    const bw = 1 + (r & 1);\n    const gap = 1 + ((r>>1) & 1);\n\n    const bar = document.createElement(\"div\");\n    bar.style.position = \"absolute\";\n    bar.style.left = x + \"px\";\n    bar.style.top = \"0px\";\n    bar.style.width = bw + \"px\";\n    bar.style.height = h + \"px\";\n    barcode.appendChild(bar);\n\n    x += bw + gap;\n  }\n}\n\nwindow.onload = drawBarcode;\n\nnew MutationObserver(drawBarcode).observe(tcEl,{\n  childList:true,\n  subtree:true,\n  characterData:true\n});\n</script>\n\n</body>\n</html>"
    }
  },
